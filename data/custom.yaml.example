# YOLO 自定义数据集配置模板
# 复制此文件为 data/custom.yaml 并根据实际情况修改路径和类别

# 训练集和验证集图片根目录（绝对路径或相对于本文件的路径）
path: ../data/custom_dataset          # 数据集根目录
train: images/train                   # 训练集图片目录（相对于 path）
val: images/val                       # 验证集图片目录（相对于 path）

# 类别数量
nc: 5

# 类别名称（按 class_id 顺序排列，必须与标注文件中的 class_id 对应）
names:
  0: character_ct     # CT 角色
  1: character_t      # T 角色
  2: weapon_rifle     # 步枪
  3: weapon_pistol    # 手枪
  4: prop             # 道具/物品
