{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reelfire.local/schemas/agent_output.schema.json",
  "title": "ReelFire Agent Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "job_id",
    "status",
    "provider",
    "summary",
    "tags",
    "suggestions",
    "review",
    "evidence_refs",
    "knowledge_refs",
    "trace",
    "errors"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "completed",
        "degraded",
        "failed"
      ]
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "model"
      ],
      "properties": {
        "type": {
          "enum": [
            "ollama",
            "dify",
            "coze",
            "rule_only"
          ]
        },
        "model": {
          "type": "string"
        },
        "request_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "summary": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "description",
          "evidence_refs"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "suggestions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "suggestion_id",
          "title",
          "action",
          "priority",
          "evidence_refs",
          "knowledge_refs"
        ],
        "properties": {
          "suggestion_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "knowledge_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recommendation",
        "confidence",
        "reasons"
      ],
      "properties": {
        "recommendation": {
          "enum": [
            "pass",
            "needs_review",
            "reject"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ref_id",
          "type",
          "source_id"
        ],
        "properties": {
          "ref_id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "enum": [
              "detection",
              "score",
              "keyframe",
              "segment",
              "report"
            ]
          },
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "timestamp": {
            "type": "number",
            "minimum": 0
          },
          "class_name": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "value": {}
        }
      }
    },
    "knowledge_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "knowledge_id",
          "category",
          "title"
        ],
        "properties": {
          "knowledge_id": {
            "type": "string",
            "pattern": "^KB-[A-Z]+-[0-9]{3}$"
          },
          "category": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "started_at",
        "finished_at",
        "duration_ms",
        "degraded",
        "tools"
      ],
      "properties": {
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "finished_at": {
          "type": "string",
          "format": "date-time"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "degraded": {
          "type": "boolean"
        },
        "input_summary_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "status",
              "duration_ms"
            ],
            "properties": {
              "name": {
                "enum": [
                  "report_parser",
                  "knowledge_retriever",
                  "advice_generator",
                  "rule_validator"
                ]
              },
              "status": {
                "enum": [
                  "completed",
                  "degraded",
                  "failed",
                  "skipped"
                ]
              },
              "duration_ms": {
                "type": "integer",
                "minimum": 0
              },
              "detail": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "message",
          "stage",
          "retryable"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "stage": {
            "type": "string"
          },
          "retryable": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
